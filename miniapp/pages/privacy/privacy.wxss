/* pages/privacy/privacy.wxss */
.privacy-page {
  min-height: 100vh;
  background: #0a0e17;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.privacy-card {
  background: #111827;
  border: 1px solid #1e293b;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  width: 100%;
}
.privacy-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #e2e8f0;
  text-align: center;
  margin-bottom: 40rpx;
}
.privacy-section {
  margin-bottom: 32rpx;
}
.privacy-heading {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #06d6a0;
  margin-bottom: 12rpx;
}
.privacy-text {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.8;
}
.agree-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #06d6a0, #118ab2);
  color: #000;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
  border: none;
}
