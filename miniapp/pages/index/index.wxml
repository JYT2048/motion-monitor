<!--pages/index/index.wxml-->
<view class="container">

  <!-- 摄像头区域（主视觉） -->
  <view class="camera-wrap" wx:if="{{cameraReady}}">
    <camera
      id="motionCamera"
      device-position="front"
      flash="off"
      mode="normal"
      resolution="medium"
      frame-size="small"
      class="camera-view"
      bindinitdone="onCameraInitDone"
      bindstop="onCameraStop"
      binderror="onCameraError"
    />
    <canvas
      type="2d"
      id="poseCanvas"
      class="pose-canvas"
    />
    <!-- 覆盖层标签 -->
    <view class="overlay-top">
      <view class="fps-tag">{{fps}} FPS</view>
      <view class="skeleton-tag" wx:if="{{showSkeleton}}">🦴 骨骼追踪</view>
      <view class="live-tag"><view class="live-dot"></view> LIVE</view>
    </view>
    <!-- 运动状态浮层 -->
    <view class="motion-overlay" wx:if="{{motionLabel !== '等待检测'}}">
      <text class="motion-emoji-lg">{{motionEmoji}}</text>
      <text class="motion-label-lg">{{motionLabel}}</text>
    </view>
  </view>

  <!-- 未启动遮罩 -->
  <view class="camera-wrap camera-wrap-placeholder" wx:if="{{!cameraReady}}">
    <view class="camera-mask">
      <view class="mask-icon">🏃</view>
      <text class="mask-title">动作捕捉</text>
      <text class="mask-desc">开启摄像头，实时捕捉人体骨骼动作</text>
      <button class="start-btn" bindtap="startCamera">开启摄像头</button>
    </view>
  </view>

  <!-- 关节角度 -->
  <view class="card" wx:if="{{cameraReady}}">
    <view class="card-title">📐 关节角度</view>
    <view class="angles-grid">
      <view class="angle-item">
        <text class="angle-name">左肘</text>
        <text class="angle-value">{{angles.leftElbow}}°</text>
      </view>
      <view class="angle-item">
        <text class="angle-name">右肘</text>
        <text class="angle-value">{{angles.rightElbow}}°</text>
      </view>
      <view class="angle-item">
        <text class="angle-name">左膝</text>
        <text class="angle-value">{{angles.leftKnee}}°</text>
      </view>
      <view class="angle-item">
        <text class="angle-name">右膝</text>
        <text class="angle-value">{{angles.rightKnee}}°</text>
      </view>
      <view class="angle-item">
        <text class="angle-name">左肩</text>
        <text class="angle-value">{{angles.leftShoulder}}°</text>
      </view>
      <view class="angle-item">
        <text class="angle-name">右肩</text>
        <text class="angle-value">{{angles.rightShoulder}}°</text>
      </view>
    </view>
  </view>

  <!-- 动作计数 -->
  <view class="card" wx:if="{{cameraReady}}">
    <view class="card-header">
      <text class="card-title">🔢 动作计数</text>
      <text class="reset-btn" bindtap="resetCounters">重置</text>
    </view>
    <view class="counter-grid">
      <view class="counter-item">
        <text class="counter-name">深蹲</text>
        <text class="counter-value">{{counters.squat}}</text>
      </view>
      <view class="counter-item">
        <text class="counter-name">举手</text>
        <text class="counter-value">{{counters.raise}}</text>
      </view>
      <view class="counter-item">
        <text class="counter-name">跳跃</text>
        <text class="counter-value">{{counters.jump}}</text>
      </view>
    </view>
  </view>

  <!-- 会话统计 -->
  <view class="card" wx:if="{{cameraReady}}">
    <view class="card-title">📊 会话</view>
    <view class="stat-row">
      <text class="stat-label">检测时长</text>
      <text class="stat-value">{{sessionTime}}</text>
    </view>
    <view class="stat-row">
      <text class="stat-label">运动时长</text>
      <text class="stat-value">{{activeTime}}</text>
    </view>
  </view>

  <!-- 诊断面板 -->
  <view class="debug-panel" wx:if="{{debugInfo}}">
    <view class="debug-header">🔧 诊断</view>
    <text class="debug-text">{{debugInfo}}</text>
  </view>

</view>
